<!DOCTYPE html>
<html>

<head>

    <title>Admin Login</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<div class="container">

    <form action="/admin/login" method="POST">

        <h1>Admin Login</h1>

        <input
            type="email"
            name="email"
            placeholder="Admin Email"
            required
        >

        <input
            type="password"
            name="password"
            placeholder="Password"
            required
        >

        <button type="submit">
            Login
        </button>

    </form>

</div>

<script src="/js/main.js"></script>

</body>

</html>
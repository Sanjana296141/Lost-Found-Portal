<!DOCTYPE html>
<html>

<head>

    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<div class="admin-layout">

    <!-- SIDEBAR -->

    <div class="sidebar">

        <h2>Admin Panel 👑</h2>

        <ul>

            <li>
                <a href="/admin/dashboard">
                    Dashboard
                </a>
            </li>

            <li>
                <a href="/items">
                    View Items
                </a>
            </li>

            <li>
                <a href="/logout">
                    Logout
                </a>
            </li>

        </ul>

    </div>

    <!-- MAIN CONTENT -->

    <div class="admin-main">

        <h1>
            Welcome Admin 🚀
        </h1>

        <!-- STATS -->

        <div class="admin-cards">

            <div class="admin-card">

                <h2>Total Users</h2>

                <p><%= users.length %></p>

            </div>

            <div class="admin-card">

                <h2>Total Items</h2>

                <p><%= items.length %></p>

            </div>

        </div>

        <!-- SEARCH -->

        <div class="search-box">

            <input
                type="text"
                id="tableSearch"
                placeholder="Search tables..."
            >

        </div>

        <!-- RECENT UPLOADS -->

        <div class="admin-section">

            <h2>Recent Uploads</h2>

            <div class="recent-uploads">

                <% items.slice(0, 4).forEach(item => { %>

                    <div class="recent-card">

                        <img
                            src="/uploads/<%= item.image %>"
                            alt="item"
                        >

                        <p>
                            <%= item.item_name %>
                        </p>

                    </div>

                <% }) %>

            </div>

        </div>

        <!-- NOTIFICATIONS -->

        <div class="admin-section">

            <h2>Notifications 🔔</h2>

            <div class="notification-box">

                <p>
                    New item uploaded successfully.
                </p>

                <p>
                    Total users increased today.
                </p>

                <p>
                    Admin dashboard updated.
                </p>

            </div>

        </div>

        <!-- USER ACTIVITY -->

        <div class="admin-section">

            <h2>User Activity Logs</h2>

            <div class="notification-box">

                <% users.forEach(user => { %>

                    <p>

                        <strong>
                            <%= user.name %>
                        </strong>

                        joined platform.

                    </p>

                <% }) %>

            </div>

        </div>

        <!-- USERS TABLE -->

        <div class="admin-section">

            <h2>Registered Users</h2>

            <div class="modern-table">

                <table>

                    <tr>

                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Action</th>

                    </tr>

                    <% users.forEach(user => { %>

                        <tr>

                            <td><%= user.id %></td>

                            <td><%= user.name %></td>

                            <td><%= user.email %></td>

                            <td>

                                <a href="/admin/delete-user/<%= user.id %>">

                                    <button class="delete-btn">
                                        Delete
                                    </button>

                                </a>

                            </td>

                        </tr>

                    <% }) %>

                </table>

            </div>

        </div>

        <!-- ITEMS TABLE -->

        <div class="admin-section">

            <h2>Uploaded Items</h2>

            <div class="modern-table">

                <table>

                    <tr>

                        <th>ID</th>
                        <th>Item</th>
                        <th>Status</th>
                        <th>Location</th>
                        <th>Actions</th>

                    </tr>

                    <% items.forEach(item => { %>

                        <tr>

                            <td><%= item.id %></td>

                            <td><%= item.item_name %></td>

                            <td><%= item.status %></td>

                            <td><%= item.location %></td>

                            <td>

                                <a href="/admin/edit-item/<%= item.id %>">

                                    <button class="edit-btn">
                                        Edit
                                    </button>

                                </a>

                                <a href="/admin/delete-item/<%= item.id %>">

                                    <button class="delete-btn">
                                        Delete
                                    </button>

                                </a>

                            </td>

                        </tr>

                    <% }) %>

                </table>

            </div>

        </div>

    </div>

</div>

<script src="/js/main.js"></script>

</body>

</html>